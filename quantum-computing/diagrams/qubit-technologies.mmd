        PHCons[- Probabilistic gates<br/>- Detection losses]
    end
    
    subgraph "Topological"
        TOP[Majorana fermions<br/>Microsoft]
        TOPPros[+ Inherent protection<br/>+ Fault tolerance]
        TOPCons[- Experimental stage<br/>- Complex fabrication]
    end
    
    subgraph "Neutral Atoms"
        NA[Optical tweezers<br/>QuEra, Pasqal]
        NAPros[+ Flexible geometry<br/>+ Long coherence]
        NACons[- Complex control<br/>- Loading challenges]
    end
    
    subgraph "Silicon Spin"
        SI[Electron spins<br/>Intel, SiQure]
        SIPros[+ CMOS compatible<br/>+ Small footprint]
        SICons[- Complex control<br/>- Scaling challenges]
    end
    
